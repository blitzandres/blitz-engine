        S25["BlitzOutput Builder (pre-narrative)\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nBlitzOutput (partial)\nrisk_score: float     вҶҗ = posterior\nuncertainty: float    вҶҗ posterior variance\ncue_attribution: list[{\n  cue_id: str\n  modality_family: str\n  weight: float\n  direction: 'increase'|'decrease'\n  evidence: float\n}]\nnarrative: null       вҶҗ filled next step\nmetadata: {session_id, t_end_ms}\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\npublish: output.blitz.ready"]

        S25 -->|"build CuePacket\n(strict outbound boundary)"| S26A

        S26A["CuePacket вҶ’ Claude API\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nOUTBOUND ONLY:\n{\n  session_id: str\n  risk_score: float\n  uncertainty: float\n  top_cues: list[{\n    label: str\n    modality_family: str\n    signed_strength: float\n    short_evidence: str\n  }]\n  constraints: {no_raw_media: true}\n}\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nвң… NO raw video\nвң… NO raw audio\nвң… NO full ASR transcript\nJSON only вҖ” external call"]

